// =============================================================================
// VerSeFusion — Nextflow configuration
//
// Profiles:
//   * local       — run on the calling host (default)
//   * slurm       — submit each process to SLURM (Warrior HPC)
//   * singularity — exec every process inside containers/versefusion.sif
//
// Combine via `-profile slurm,singularity`.
// =============================================================================

manifest {
    name        = 'VerSeFusion'
    description = 'Download, unify, and benchmark-export VerSe19 + VerSe20'
    version     = '0.1.0'
    author      = 'Gregory J. Schwing'
    mainScript  = 'main.nf'
}

// shared defaults ------------------------------------------------------------
process {
    errorStrategy = { task.attempt < 2 ? 'retry' : 'finish' }
    maxRetries    = 1
    cache         = 'lenient'
}

// profiles -------------------------------------------------------------------
profiles {
    local {
        process.executor = 'local'
    }

    slurm {
        process {
            executor      = 'slurm'
            queue         = 'compute'
            clusterOptions = '--qos=normal --account=neurosurg'
        }
    }

    singularity {
        singularity {
            enabled    = true
            autoMounts = true
        }
        process {
            container = 'docker://gschwing/versefusion:v0.1.0'
        }
    }
}

// reporting ------------------------------------------------------------------
trace {
    enabled = true
    file    = "${params.reoriented_dir}/../trace.txt"
    overwrite = true
}
report {
    enabled = true
    file    = "${params.reoriented_dir}/../report.html"
    overwrite = true
}
timeline {
    enabled = true
    file    = "${params.reoriented_dir}/../timeline.html"
    overwrite = true
}
dag {
    enabled = true
    file    = "${params.reoriented_dir}/../dag.dot"
    overwrite = true
}
