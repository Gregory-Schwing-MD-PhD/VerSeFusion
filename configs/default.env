# =============================================================================
# VerSeFusion — default environment
#
# This file is checked into git and must contain ONLY non-secret defaults.
# Put HF_TOKEN, S3 keys, etc. in env.local (which is gitignored).
# =============================================================================

# --- canonical paths ----------------------------------------------------------
DATA_DIR=$(CURDIR)/data
RAW_DIR=$(DATA_DIR)/raw
UNIFIED_DIR=$(DATA_DIR)/unified
REORIENTED_DIR=$(DATA_DIR)/reoriented
HF_DIR=$(DATA_DIR)/hf_export
LOG_DIR=$(CURDIR)/logs

# --- VerSe upstream sources (BIDS-restructured, recommended) ------------------
VERSE_S3_BASE=https://s3.bonescreen.de/public/VerSe-complete

# Each release ships as three zips: training / validation / test
VERSE19_ZIPS=dataset-verse19training.zip dataset-verse19validation.zip dataset-verse19test.zip
VERSE20_ZIPS=dataset-verse20training.zip dataset-verse20validation.zip dataset-verse20test.zip

# --- dedup policy -------------------------------------------------------------
# When a subject appears in both releases, prefer VerSe20 (newer annotations,
# fracture grading included).  Set to "verse19" to invert.
DEDUP_PREFER=verse20

# --- reorientation ------------------------------------------------------------
# Target orientation in NIBABEL axcode form.  PIR matches CTSpinoPelvic1K.
TARGET_ORIENTATION=PIR

# --- LSTV / T13 detection -----------------------------------------------------
# VerSe label values that flag an enumeration anomaly.
LSTV_LABEL=25      # L6 (lumbarized LSTV)
T13_LABEL=28       # extra thoracic vertebra

# --- splits -------------------------------------------------------------------
N_FOLDS=5
SPLIT_SEED=20260511
STRATIFY_AXES=lstv,t13

# --- HuggingFace export -------------------------------------------------------
HF_DATASET_NAME=VerSeFusion
HF_DATASET_VERSION=v0.1.0
# Put HF_TOKEN in env.local, not here.

# --- HPC / SLURM (Warrior cluster) --------------------------------------------
SLURM_PARTITION=compute
SLURM_QOS=normal
SLURM_TIME=04:00:00
SLURM_MEM=32G
SLURM_CPUS=8
SLURM_ACCOUNT=neurosurg

# Singularity container (pulled from Docker Hub).
CONTAINER_IMAGE=docker://gschwing/versefusion:v0.1.0
CONTAINER_SIF=$(CURDIR)/containers/versefusion.sif

# --- python -------------------------------------------------------------------
PYTHON=python3
