# =============================================================================
# VerSeFusion — default environment
#
# Non-secret defaults only.  Pure single-word scalar values — NO multi-word
# lists and NO path expressions that need Make-style $(CURDIR) expansion,
# because this file is also sourced from slurm/_common.sh as plain bash.
#
# Path defaults (DATA_DIR, RAW_DIR, etc.) live in the Makefile (`?=` defaults)
# and slurm/_common.sh (`${VAR:-${REPO_ROOT}/...}` defaults).
#
# Per-release file lists are hard-coded in src/verse_pipeline/download.py;
# they are not parameterized here.
#
# Put HF_TOKEN, S3 keys, etc. in env.local (gitignored).
# =============================================================================

# --- VerSe upstream root (single URL, no spaces) -----------------------------
VERSE_S3_BASE=https://s3.bonescreen.de/public/VerSe-complete

# --- dedup policy -------------------------------------------------------------
# When a subject appears in both releases, prefer VerSe20 (newer annotations,
# fracture grading included).  Set to "verse19" to invert.
DEDUP_PREFER=verse20

# --- reorientation ------------------------------------------------------------
TARGET_ORIENTATION=PIR

# --- LSTV / T13 detection -----------------------------------------------------
LSTV_LABEL=25
T13_LABEL=28

# --- splits -------------------------------------------------------------------
N_FOLDS=5
SPLIT_SEED=20260511
HOLDOUT_MODE=verse20_test

# --- HuggingFace export -------------------------------------------------------
HF_DATASET_NAME=VerSeFusion
HF_DATASET_VERSION=v0.1.0
# HF_TOKEN goes in env.local, not here.

# --- HPC / SLURM (Warrior cluster) --------------------------------------------
SLURM_QOS=primary
SLURM_TIME=04:00:00
SLURM_MEM=32G
SLURM_CPUS=8

# --- container image (path lives in Makefile / _common.sh) -------------------
CONTAINER_IMAGE=docker://gregoryschwingmdphd/ctspinopelvic1k:latest

# --- python -------------------------------------------------------------------
PYTHON=python3
